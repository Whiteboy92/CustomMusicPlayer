<UserControl x:Class="MusicPlayer.Views.Player.PlayerControlsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="800">
    
    <UserControl.Resources>
        <!-- Volume Icon Style -->
        <Style x:Key="VolumeIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.15" ScaleY="1.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Progress Bar and Time -->
        <Border Grid.Row="0" Margin="0,0,0,10" BorderBrush="#333333" BorderThickness="1" CornerRadius="5" Background="#2d2d2d">
            <Grid Margin="15,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Name="TxtCurrentTime" Text="00:00" 
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                
                <Slider Grid.Column="1" Name="ProgressSlider" 
                        Minimum="0" Maximum="100" Value="0"
                        VerticalAlignment="Center"
                        Style="{StaticResource ModernSliderStyle}"
                        Thumb.DragStarted="ProgressSlider_DragStarted"
                        Thumb.DragCompleted="ProgressSlider_DragCompleted"/>
                
                <TextBlock Grid.Column="2" Name="TxtTotalTime" Text="00:00" 
                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- Control Panel -->
        <Border Grid.Row="1" BorderBrush="#333333" BorderThickness="1" CornerRadius="5" Background="#2d2d2d">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Volume Control with Speaker Icon and Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!-- Volume Down Button -->
                    <Button
                        Style="{StaticResource RoundedButtonStyle}"
                            Width="44" Height="44"
                            Click="BtnVolumeDown_Click"
                            Margin="0,0,5,0">
                        <Canvas Width="16" Height="16">
                            <!-- Minus Sign (Horizontal Rectangle) -->
                            <Rectangle Width="16" Height="2.5" 
                                       Canvas.Left="0" Canvas.Top="6.75"
                                       Fill="{StaticResource TextBrush}"/>
                        </Canvas>
                    </Button>
                    
                    <!-- Speaker Icon with Popup -->
                    <Grid Name="VolumeControl" 
                          MouseEnter="VolumeControl_MouseEnter"
                          MouseLeave="VolumeControl_MouseLeave">
                        <TextBlock Name="SpeakerIcon" 
                                   Text="🔊" 
                                   Style="{StaticResource VolumeIconStyle}"
                                   VerticalAlignment="Center"/>
                        
                        <!-- Volume Popup -->
                        <Popup Name="VolumePopup" 
                               PlacementTarget="{Binding ElementName=SpeakerIcon}"
                               Placement="Top"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               VerticalOffset="10">
                            <Border Background="#2d2d2d" 
                                    BorderBrush="#4a4a4a" 
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Padding="10,15"
                                    MouseEnter="VolumePopup_MouseEnter"
                                    MouseLeave="VolumePopup_MouseLeave">
                                <StackPanel>
                                    <!-- Volume Percentage Display -->
                                    <TextBlock Name="TxtVolume" 
                                               Text="3%" 
                                               Foreground="{StaticResource TextBrush}" 
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    
                                    <!-- Vertical Volume Slider -->
                                    <Slider Name="VolumeSlider" 
                                            Orientation="Vertical"
                                            Height="120"
                                            Width="40"
                                            Minimum="0" 
                                            Maximum="100" 
                                            Value="3"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="False"
                                            ValueChanged="VolumeSlider_ValueChanged"
                                            HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    
                    <!-- Volume Up Button -->
                    <Button
                        Style="{StaticResource RoundedButtonStyle}"
                            Width="44" Height="44"
                            Click="BtnVolumeUp_Click"
                            Margin="5,0,0,0">
                        <Canvas Width="16" Height="16">
                            <!-- Plus Sign (Two Rectangles) -->
                            <Rectangle Width="16" Height="2.5" 
                                       Canvas.Left="0" Canvas.Top="6.75"
                                       Fill="{StaticResource TextBrush}"/>
                            <!-- Vertical bar -->
                            <Rectangle Width="2.5" Height="16" 
                                       Canvas.Left="6.75" Canvas.Top="0"
                                       Fill="{StaticResource TextBrush}"/>
                        </Canvas>
                    </Button>
                </StackPanel>

                <!-- Playback Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Padding="18,12" Margin="5"
                            MinWidth="110"
                            Style="{StaticResource RoundedButtonStyle}"
                            Click="BtnPrevious_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="16" Height="16" Stretch="Uniform"
                                  Fill="{StaticResource TextBrush}"
                                  Data="M6,5 L6,19 L8,19 L8,5 Z M20,5 L20,19 L9,12 Z"/>
                            <TextBlock Text="Previous" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Name="BtnPlayPause" Padding="18,12" Margin="5"
                            MinWidth="120"
                            Style="{StaticResource PlayButtonStyle}"
                            Click="BtnPlayPause_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Name="PlayPauseIcon" Width="16" Height="16" Stretch="Uniform"
                                  Fill="{StaticResource TextBrush}"
                                  Data="M7,4 L7,20 L20,12 Z"/>
                            <TextBlock Name="PlayPauseLabel" Text="Play" FontSize="14" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Padding="18,12" Margin="5"
                            MinWidth="110"
                            Style="{StaticResource RoundedButtonStyle}"
                            Click="BtnShuffle_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="16" Height="16" Stretch="Uniform"
                                  Stroke="{StaticResource TextBrush}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Data="M3,6 H7 L17,18 H21 M18,15 L21,18 L18,21 M3,18 H7 L17,6 H21 M18,3 L21,6 L18,9"/>
                            <TextBlock Text="Shuffle" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Padding="18,12" Margin="5"
                            MinWidth="110"
                            Style="{StaticResource RoundedButtonStyle}"
                            Click="BtnNext_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Next" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Path Width="16" Height="16" Stretch="Uniform"
                                  Fill="{StaticResource TextBrush}"
                                  Data="M18,5 L18,19 L16,19 L16,5 Z M4,5 L4,19 L15,12 Z"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Autoplay toggle (right side) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,5,0">
                    <TextBlock Text="Autoplay"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <ToggleButton x:Name="BtnAutoplay" IsChecked="True"
                                  Cursor="Hand" VerticalAlignment="Center"
                                  Checked="BtnAutoplay_Checked"
                                  Unchecked="BtnAutoplay_Unchecked">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="Track" Width="48" Height="26"
                                        CornerRadius="13" Background="#555555">
                                    <Ellipse x:Name="Knob" Width="20" Height="20"
                                             Fill="White"
                                             HorizontalAlignment="Left"
                                             Margin="3,0,0,0"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="Track" Property="Background"
                                                Value="{StaticResource AccentBrush}"/>
                                        <Setter TargetName="Knob" Property="HorizontalAlignment"
                                                Value="Right"/>
                                        <Setter TargetName="Knob" Property="Margin"
                                                Value="0,0,3,0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
